{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "westeurope"
    },
    "locationSpoke03": {
      "type": "string",
      "defaultValue": "northeurope"
    }
  },
  "variables": {
    "hubVnetName": "hub-lab-net",
    "spoke01Name": "spoke-01",
    "spoke02Name": "spoke-02",
    "spoke03Name": "spoke-03"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('hubVnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.12.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "DefaultSubnet",
            "properties": {
              "addressPrefix": "10.12.1.0/24"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke01Name')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.13.1.0/24"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "10.13.1.0/26"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke02Name')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.13.2.0/24"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "10.13.2.0/26"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke03Name')]",
      "location": "[parameters('locationSpoke03')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.13.3.0/24"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "10.13.3.0/26"
            }
          }
        ]
      }
    },

    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('hubVnetName'), '/hub-to-spoke01')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke01Name'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke01Name'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('spoke01Name'), '/spoke01-to-hub')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke01Name'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    },

    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('hubVnetName'), '/hub-to-spoke02')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke02Name'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke02Name'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('spoke02Name'), '/spoke02-to-hub')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke02Name'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    },

    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('hubVnetName'), '/hub-to-spoke03')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke03Name'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke03Name'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('spoke03Name'), '/spoke03-to-hub')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('spoke03Name'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
      ],
      "properties": {
        "remoteVirtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
        },
        "allowVirtualNetworkAccess": true
      }
    }
  ]
}
